OPENAI_API_KEY=sk-your-key-here

# Database Configuration
# Using SQLite for local development temporarily
DATABASE_URL=sqlite:///./proofhire.db
# When moving to Supabase/PostgreSQL, update this to:
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Llama API Configuration
LLAMA_API_KEY=your_llama_api_key_here

# Comma-separated deployed frontend origins allowed by CORS
FRONTEND_ORIGINS=https://your-frontend.vercel.app

# Use a long random value in production
AUTH_SECRET=change-me-before-deploy
